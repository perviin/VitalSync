# Configuration d'environnement pour VitalSync
# Ce fichier .env.example sert de template
# Créez un fichier .env avec vos vraies valeurs (NE PAS COMMITER)

# Base de données PostgreSQL
DB_USER=vitalsync_user
DB_PASSWORD=your-super-secret-password-change-me
DB_NAME=vitalsync_db

# Backend API
NODE_ENV=production
PORT=3000
API_URL=http://localhost:3000

# Frontend
# URL publique du frontend (utilisé pour les redirects)
FRONTEND_URL=http://localhost

# Sécurité (à activer en production)
# JWT_SECRET=your-jwt-secret-key-here
# API_KEY=your-api-key-here
