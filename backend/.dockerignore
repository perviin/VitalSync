# Contrôle de version - Métadonnées du dépôt inutiles dans l'image
.git/                       # Historique du dépôt Git (100+MB, aucune valeur runtime)
.gitignore                  # Configuration Git (inutile au runtime)
.github/                    # Workflows GitHub et CI/CD (réservé au dev)

# Documentation - Référence uniquement, inutile en production
README.md                   # Documentation du projet
*.md                        # Tous les fichiers markdown
docs/                       # Dossier de documentation
CHANGELOG.md                # Historique des versions

# IDE et Éditeur - Fichiers de configuration personnelle
.vscode/                    # Configuration VSCode (utilisateur-spécifique)
.idea/                      # Configuration IntelliJ
*.swp                       # Fichiers temporaires Vim
*.swo                       # Fichiers swap Vim
*~                          # Fichiers de sauvegarde d'éditeur
.DS_Store                   # Métadonnées macOS

# Logs - Artefacts runtime des builds précédents
npm-debug.log*              # Logs de débogage npm
yarn-debug.log*             # Logs de débogage Yarn
yarn-error.log*             # Logs d'erreur Yarn
*.log                       # Tous les fichiers journaux

# Node.js - Exclu pour éviter la duplication (réinstallé dans le conteneur)
node_modules/               # Dépendances réinstallées via npm install en stage builder
package-lock.json           # Fichier de verrouillage (nouvel install dans builder)

# Environnement - Les secrets ne doivent pas être intégrés dans l'image
.env*                       # Fichiers d'environnement avec secrets potentiels
*.pem                       # Certificats SSL/TLS
*.key                       # Clés privées

# Artefacts de build - Artefacts inutiles des builds précédents
dist/                       # Code compilé
build/                      # Résultats de la compilation
.next/                      # Artefacts de build Next.js
coverage/                   # Rapports de couverture de tests
.nyc_output/                # Données de couverture NYC

# Fichiers de test - Non exécutés en production, réduisent la taille
test/                       # Dossier test (tests exécutés en stage builder)
*.test.js                   # Fichiers de test
jest.config.js              # Configuration Jest
supertest/                  # Dépendances de test

# Docker - Exclure les fichiers config Docker
Dockerfile                  # Ce Dockerfile (prévient les références circulaires)
docker-compose.yml          # Fichier Compose (inutile dans l'image)
.dockerignore               # Ce fichier .dockerignore
.dockerignore               # This file itself
docker/                     # Docker configuration folder

# Temporary files and cache - Clutter and increase size
tmp/                        # Temporary directory
temp/                       # Temporary directory
*.tmp                       # Temporary files
.cache/                     # Cache directory
.npm/                       # npm cache (will be clean in fresh installation)

# Package manager lock files - Excluded to ensure controlled installation
pnpm-lock.yaml              # pnpm lock file
yarn.lock                   # Yarn lock file

# Frontend (if present) - Separate container/build process
frontend/                   # Frontend folder (separate image)
nginx.conf                  # Nginx config (for frontend/proxy)
